{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/check-changelog.sh\"",
            "timeout": 10,
            "statusMessage": "Checking whether changelog.md has been updated..."
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/check-readme-on-version-bump.sh\"",
            "timeout": 10,
            "statusMessage": "Checking whether the README has been updated after the version change..."
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/check-root-readme-on-new-files.sh\"",
            "timeout": 10,
            "statusMessage": "Checking whether the root README has been updated after adding new files..."
          }
        ]
      }
    ]
  }
}
